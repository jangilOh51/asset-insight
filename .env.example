# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/asset_insight
REDIS_URL=redis://localhost:6379/0

# KIS API (https://apiportal.koreainvestment.com)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=          # 계좌번호 XXXXXXXXXX-XX 형식
KIS_MOCK=false           # true=모의투자, false=실전투자 (실계좌 사용)
KIS_OVERSEAS_EXCHANGES=["NASD","NYSE","AMEX"]   # 조회할 해외 거래소

# 키움증권 OpenAPI+ REST (https://openapi.kiwoom.com)
# 계좌별 API 키를 /accounts 등록 UI에서 입력하는 것을 권장
# 전역 설정은 단일 키움 계좌만 있을 때 편의용으로 사용
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=       # 계좌번호 XXXXXXXXXX-XX 형식
KIWOOM_MOCK=false        # true=모의투자

# Scheduler
SNAPSHOT_CRON=0 18 * * 1-5       # 평일 18시 (장 마감 후 스냅샷)
NOTIFICATION_INTERVAL_MINUTES=30  # 알림 체크 주기 (분)
REALTIME_THROTTLE_SECONDS=600     # 실시간 조회 스냅샷 저장 최소 간격 (초)

# Notification thresholds
NOTIF_HIGH_RETURN_PCT=20.0   # 이상 수익률 기준 (%)
NOTIF_HIGH_LOSS_PCT=-15.0    # 이상 손실 기준 (%)

# AI (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# App
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]
