# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/asset_insight
REDIS_URL=redis://localhost:6379/0

# KIS API (https://apiportal.koreainvestment.com)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=          # 계좌번호 XXXXXXXXXX-XX 형식
KIS_MOCK=true            # true=모의투자, false=실전투자

# Scheduler
SNAPSHOT_CRON=0 18 * * 1-5   # 평일 18시 (장 마감 후 스냅샷)

# App
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Optional: 해외주식 환율 API
EXCHANGE_RATE_API_KEY=
